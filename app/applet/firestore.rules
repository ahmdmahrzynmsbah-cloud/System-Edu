rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /system_tenants/{document=**} {
      allow read, write: if true;
    }
    match /system_users/{document=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
